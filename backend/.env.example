PORT=5000
# Real MongoDB (leave USE_MEMORY_DB unset or false)
MONGODB_URI=mongodb://127.0.0.1:27017/smart_expense_tracker
# Set to true for local dev without installing MongoDB (data is not persisted)
USE_MEMORY_DB=false
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
